.key Switch1/S,Arg1/K,ArgX/M
.bra {
.ket }
; $VER: WHDLoad-Startup 1.0 (26.06.26)    
;
        
c:areweonline
If $RC EQ 0
   IF EXISTS ENV:IPStack
      SYS:Rexxc/rx SYS:pistorm/network/network.rexx Action=Disconnect IPStack=$IPStack KeepEnvStatus SilentRunning
   ENDIF
ELSE
;If somehow we are offline but the environment variables are set, then remove them. This prevents the cleanup script bringing the Amiga online when it was offline to start
	Unsetenv IPStack 
	Unsetenv ConnectionType
ENDIF


